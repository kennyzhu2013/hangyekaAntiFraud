# LLM 配置（OpenAI 兼容协议，通义/DeepSeek/Kimi 等均可通过 base_url 接入）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.1

# 融合策略：置信度低于该阈值自动送人工复核
LOW_CONF_THRESHOLD=0.6

# 异常检测（V1 保持关闭；V2 接入 PyOD 在线打分后开启）
ANOMALY_ENABLED=false
ANOMALY_MODEL_DIR=
